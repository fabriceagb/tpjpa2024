INSERT INTO EVENT VALUES(TRUE,300,5,200.0E0,1,'2026-05-14 23:00:00.000000',1,1,'Le plus grand rassemblement des passionn\u00e9s de technologie en Bretagne revient pour une \u00e9dition 2026 exceptionnelle ! Pendant deux jours intenses, plongez au c\u0153ur de l''innovation gr\u00e2ce \u00e0 un programme riche compos\u00e9 de conf\u00e9rences inspirantes, d''ateliers pratiques et de sessions de networking strat\u00e9giques, le tout articul\u00e9 autour des trois piliers fondamentaux de notre \u00e9poque : l''Intelligence Artificielle, le d\u00e9veloppement Web de demain et la cybers\u00e9curit\u00e9.\u000a\u000aAu programme de cette \u00e9dition :\u000a\u000aIntelligence Artificielle & Data : D\u00e9couvrez comment l''IA g\u00e9n\u00e9rative red\u00e9finit les fronti\u00e8res de la cr\u00e9ation logicielle et de l''automatisation. Nos experts internationaux partageront leurs retours d''exp\u00e9rience sur l''int\u00e9gration de mod\u00e8les de langage dans des architectures complexes, l''\u00e9thique de l''IA et l''analyse pr\u00e9dictive.\u000a\u000aInnovations Web & Cloud : Pr\u00e9parez-vous \u00e0 explorer les derni\u00e8res tendances de l''\u00e9cosyst\u00e8me. Nous aborderons l''\u00e9volution des frameworks front-end (dont des masterclasses avanc\u00e9es sur Angular), l''optimisation des performances, l''\u00e9co-conception num\u00e9rique (Green IT) et les architectures Serverless qui propulsent les applications modernes.\u000a\u000aCybers\u00e9curit\u00e9 & R\u00e9silience : La s\u00e9curit\u00e9 n''\u00e9tant plus une option, un espace entier sera d\u00e9di\u00e9 \u00e0 la protection des donn\u00e9es. Assistez \u00e0 des d\u00e9monstrations de "Red Teaming" et de hacking \u00e9thique en direct, apprenez \u00e0 s\u00e9curiser vos API, et participez \u00e0 nos tables rondes sur l''approche Zero Trust.\u000a\u000aUn lieu d''\u00e9change et d''opportunit\u00e9s :\u000aOrganis\u00e9 au majestueux Couvent des Jacobins en plein centre de Rennes, cet \u00e9v\u00e9nement est l''occasion r\u00eav\u00e9e pour \u00e9tendre votre r\u00e9seau. Que vous soyez un d\u00e9veloppeur cherchant de nouveaux d\u00e9fis, un fondateur de startup en qu\u00eate d''investisseurs, ou un DSI souhaitant moderniser son infrastructure, nos espaces de rencontres B2B (Business to Business) et notre grande soir\u00e9e de cl\u00f4ture sont faits pour vous.\u000a\u000aVous aurez l''opportunit\u00e9 de rencontrer plus de 50 exposants, de participer \u00e0 un hackathon nocturne, et d''\u00e9changer avec les recruteurs des entreprises tech les plus dynamiques de la r\u00e9gion. Ne manquez pas cette occasion unique de fa\u00e7onner le futur de la tech en Bretagne !','Rennes Tech Summit 2026','Rennes, France')
COMMIT
